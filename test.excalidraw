{"type":"excalidraw","version":2,"source":"https://excalidraw.com","elements":[{"id":"title","type":"text","x":600,"y":20,"width":600,"height":60,"angle":0,"strokeColor":"#1971c2","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":1,"version":1,"versionNonce":1,"isDeleted":false,"hasFixedBounds":false,"text":"Login Project — Full Architecture & Test Flow","fontSize":28,"fontFamily":1,"textAlign":"center","verticalAlign":"top","baseline":25,"containerId":null,"originalText":"Login Project — Full Architecture & Test Flow","lineHeight":1.25},{"id":"user-box","type":"rectangle","x":710,"y":110,"width":180,"height":60,"angle":0,"strokeColor":"#2f9e44","backgroundColor":"#d3f9d8","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":{"type":3},"seed":2,"version":1,"versionNonce":2,"isDeleted":false},{"id":"user-label","type":"text","x":750,"y":128,"width":100,"height":24,"angle":0,"strokeColor":"#2f9e44","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":3,"version":1,"versionNonce":3,"isDeleted":false,"hasFixedBounds":false,"text":"👤 User / Browser","fontSize":14,"fontFamily":1,"textAlign":"center","verticalAlign":"middle","baseline":12,"containerId":null,"originalText":"👤 User / Browser","lineHeight":1.25},{"id":"arrow-user-fe","type":"arrow","x":800,"y":170,"width":0,"height":60,"angle":0,"strokeColor":"#555","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":{"type":2},"seed":4,"version":1,"versionNonce":4,"isDeleted":false,"startBinding":{"elementId":"user-box","focus":0,"gap":1},"endBinding":{"elementId":"frontend-box","focus":0,"gap":1},"lastCommittedPoint":null,"startArrowhead":null,"endArrowhead":"arrow","points":[[0,0],[0,60]]},{"id":"frontend-box","type":"rectangle","x":540,"y":240,"width":520,"height":280,"angle":0,"strokeColor":"#1971c2","backgroundColor":"#e7f5ff","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":{"type":3},"seed":5,"version":1,"versionNonce":5,"isDeleted":false},{"id":"frontend-label","type":"text","x":680,"y":250,"width":240,"height":24,"angle":0,"strokeColor":"#1971c2","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":6,"version":1,"versionNonce":6,"isDeleted":false,"hasFixedBounds":false,"text":"⚛️  Next.js 15 Frontend  (port 3000)","fontSize":15,"fontFamily":1,"textAlign":"center","verticalAlign":"top","baseline":13,"containerId":null,"originalText":"⚛️  Next.js 15 Frontend  (port 3000)","lineHeight":1.25},{"id":"pages-text","type":"text","x":560,"y":284,"width":480,"height":220,"angle":0,"strokeColor":"#1971c2","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":7,"version":1,"versionNonce":7,"isDeleted":false,"hasFixedBounds":false,"text":"Pages:\n  /register       → Registration form (phone, name, address, city)\n  /login          → OTP login (Admin) OR Login-Code (Employee)\n  /dashboard      → Admin: stats, profile card\n                    Employee: personal dashboard\n  /dashboard/employees  → CRUD employee management\n  /dashboard/tasks      → Task list + daily reports\n  /dashboard/teams      → Teams management\n  /dashboard/projects   → Projects management\n\nServices:  api.ts  →  authService, employeeService,\n                       taskService, reportService,\n                       projectService, teamService","fontSize":13,"fontFamily":1,"textAlign":"left","verticalAlign":"top","baseline":12,"containerId":null,"originalText":"Pages:\n  /register       → Registration form (phone, name, address, city)\n  /login          → OTP login (Admin) OR Login-Code (Employee)\n  /dashboard      → Admin: stats, profile card\n                    Employee: personal dashboard\n  /dashboard/employees  → CRUD employee management\n  /dashboard/tasks      → Task list + daily reports\n  /dashboard/teams      → Teams management\n  /dashboard/projects   → Projects management\n\nServices:  api.ts  →  authService, employeeService,\n                       taskService, reportService,\n                       projectService, teamService","lineHeight":1.25},{"id":"arrow-fe-be","type":"arrow","x":800,"y":520,"width":0,"height":60,"angle":0,"strokeColor":"#555","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":{"type":2},"seed":8,"version":1,"versionNonce":8,"isDeleted":false,"startBinding":{"elementId":"frontend-box","focus":0,"gap":1},"endBinding":{"elementId":"backend-box","focus":0,"gap":1},"lastCommittedPoint":null,"startArrowhead":null,"endArrowhead":"arrow","points":[[0,0],[0,60]]},{"id":"arrow-be-fe","type":"arrow","x":820,"y":520,"width":0,"height":60,"angle":0,"strokeColor":"#e03131","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":{"type":2},"seed":9,"version":1,"versionNonce":9,"isDeleted":false,"startBinding":{"elementId":"backend-box","focus":0,"gap":1},"endBinding":{"elementId":"frontend-box","focus":0,"gap":1},"lastCommittedPoint":null,"startArrowhead":null,"endArrowhead":"arrow","points":[[0,60],[0,0]]},{"id":"http-label","type":"text","x":828,"y":538,"width":100,"height":24,"angle":0,"strokeColor":"#555","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":10,"version":1,"versionNonce":10,"isDeleted":false,"hasFixedBounds":false,"text":"HTTP / REST","fontSize":12,"fontFamily":1,"textAlign":"left","verticalAlign":"top","baseline":10,"containerId":null,"originalText":"HTTP / REST","lineHeight":1.25},{"id":"backend-box","type":"rectangle","x":460,"y":590,"width":680,"height":360,"angle":0,"strokeColor":"#e67700","backgroundColor":"#fff9db","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":{"type":3},"seed":11,"version":1,"versionNonce":11,"isDeleted":false},{"id":"backend-label","type":"text","x":640,"y":600,"width":320,"height":24,"angle":0,"strokeColor":"#e67700","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":12,"version":1,"versionNonce":12,"isDeleted":false,"hasFixedBounds":false,"text":"🐍  FastAPI Backend  (port 8000)","fontSize":15,"fontFamily":1,"textAlign":"center","verticalAlign":"top","baseline":13,"containerId":null,"originalText":"🐍  FastAPI Backend  (port 8000)","lineHeight":1.25},{"id":"backend-text","type":"text","x":480,"y":634,"width":640,"height":300,"angle":0,"strokeColor":"#e67700","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":13,"version":1,"versionNonce":13,"isDeleted":false,"hasFixedBounds":false,"text":"Routers (in main.py):\n  POST /register          → Register admin company\n  POST /send-otp          → Send OTP to phone (returns otp in dev)\n  POST /verify-otp        → Verify OTP → returns JWT token\n  POST /employees         → Create employee (+ Login Code)\n  GET  /employees         → List employees for company\n  PUT  /employees/{id}    → Update employee\n  DELETE /employees/{id}  → Delete employee\n  GET  /tasks             → Get tasks (admin: all | employee: assigned)\n  POST /tasks             → Create task\n  PUT  /tasks/{id}        → Update task\n  DELETE /tasks/{id}      → Delete task\n  POST /reports           → Employee daily update\n  GET  /reports           → Get reports (filter by task)\n  GET/POST /projects      → Project CRUD\n  GET/POST /teams         → Team CRUD\n\nModels:  User · Employee · OTPStore · Task · AssignTask\n         Project · Team\nAuth:    JWT Bearer token (30 min expiry)","fontSize":13,"fontFamily":1,"textAlign":"left","verticalAlign":"top","baseline":12,"containerId":null,"originalText":"Routers (in main.py):\n  POST /register          → Register admin company\n  POST /send-otp          → Send OTP to phone (returns otp in dev)\n  POST /verify-otp        → Verify OTP → returns JWT token\n  POST /employees         → Create employee (+ Login Code)\n  GET  /employees         → List employees for company\n  PUT  /employees/{id}    → Update employee\n  DELETE /employees/{id}  → Delete employee\n  GET  /tasks             → Get tasks (admin: all | employee: assigned)\n  POST /tasks             → Create task\n  PUT  /tasks/{id}        → Update task\n  DELETE /tasks/{id}      → Delete task\n  POST /reports           → Employee daily update\n  GET  /reports           → Get reports (filter by task)\n  GET/POST /projects      → Project CRUD\n  GET/POST /teams         → Team CRUD\n\nModels:  User · Employee · OTPStore · Task · AssignTask\n         Project · Team\nAuth:    JWT Bearer token (30 min expiry)","lineHeight":1.25},{"id":"arrow-be-db","type":"arrow","x":800,"y":950,"width":0,"height":60,"angle":0,"strokeColor":"#555","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":{"type":2},"seed":14,"version":1,"versionNonce":14,"isDeleted":false,"startBinding":{"elementId":"backend-box","focus":0,"gap":1},"endBinding":{"elementId":"db-box","focus":0,"gap":1},"lastCommittedPoint":null,"startArrowhead":null,"endArrowhead":"arrow","points":[[0,0],[0,60]]},{"id":"db-box","type":"rectangle","x":620,"y":1020,"width":360,"height":80,"angle":0,"strokeColor":"#862e9c","backgroundColor":"#f3d9fa","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":{"type":3},"seed":15,"version":1,"versionNonce":15,"isDeleted":false},{"id":"db-label","type":"text","x":660,"y":1048,"width":280,"height":24,"angle":0,"strokeColor":"#862e9c","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":16,"version":1,"versionNonce":16,"isDeleted":false,"hasFixedBounds":false,"text":"🐘  PostgreSQL  (SQLAlchemy ORM)","fontSize":15,"fontFamily":1,"textAlign":"center","verticalAlign":"middle","baseline":12,"containerId":null,"originalText":"🐘  PostgreSQL  (SQLAlchemy ORM)","lineHeight":1.25},{"id":"testing-box","type":"rectangle","x":1250,"y":110,"width":560,"height":1000,"angle":0,"strokeColor":"#c92a2a","backgroundColor":"#fff5f5","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":{"type":3},"seed":17,"version":1,"versionNonce":17,"isDeleted":false},{"id":"testing-label","type":"text","x":1370,"y":120,"width":320,"height":24,"angle":0,"strokeColor":"#c92a2a","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":18,"version":1,"versionNonce":18,"isDeleted":false,"hasFixedBounds":false,"text":"🧪  Test Suite","fontSize":17,"fontFamily":1,"textAlign":"center","verticalAlign":"top","baseline":15,"containerId":null,"originalText":"🧪  Test Suite","lineHeight":1.25},{"id":"backend-test-box","type":"rectangle","x":1270,"y":160,"width":520,"height":360,"angle":0,"strokeColor":"#e67700","backgroundColor":"#fff9db","fillStyle":"solid","strokeWidth":1,"strokeStyle":"dashed","roughness":0,"opacity":100,"groupIds":[],"roundness":{"type":3},"seed":19,"version":1,"versionNonce":19,"isDeleted":false},{"id":"backend-test-label","type":"text","x":1380,"y":170,"width":300,"height":20,"angle":0,"strokeColor":"#e67700","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":20,"version":1,"versionNonce":20,"isDeleted":false,"hasFixedBounds":false,"text":"Backend API Tests  (backend/tests/)","fontSize":13,"fontFamily":1,"textAlign":"center","verticalAlign":"top","baseline":11,"containerId":null,"originalText":"Backend API Tests  (backend/tests/)","lineHeight":1.25},{"id":"backend-test-text","type":"text","x":1285,"y":200,"width":490,"height":310,"angle":0,"strokeColor":"#e67700","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":21,"version":1,"versionNonce":21,"isDeleted":false,"hasFixedBounds":false,"text":"Setup (conftest.py):\n  • In-memory SQLite DB (no real DB needed)\n  • FastAPI TestClient (no real server needed)\n  • Fixtures: db, client, admin_token, auth_client\n\ntest_auth.py\n  ✓ register new company\n  ✓ send OTP\n  ✓ verify OTP → get JWT\n\ntest_employee.py\n  ✓ create employee\n  ✓ list employees\n  ✓ login code generated (starts with 'Emp')\n\ntest_task.py\n  ✓ create task\n  ✓ list tasks\n  ✓ update task status\n  ✓ delete task\n\nRun:  venv\\Scripts\\pytest tests -v\nDB:   SQLite :memory: (isolated per test)","fontSize":13,"fontFamily":1,"textAlign":"left","verticalAlign":"top","baseline":12,"containerId":null,"originalText":"Setup (conftest.py):\n  • In-memory SQLite DB (no real DB needed)\n  • FastAPI TestClient (no real server needed)\n  • Fixtures: db, client, admin_token, auth_client\n\ntest_auth.py\n  ✓ register new company\n  ✓ send OTP\n  ✓ verify OTP → get JWT\n\ntest_employee.py\n  ✓ create employee\n  ✓ list employees\n  ✓ login code generated (starts with 'Emp')\n\ntest_task.py\n  ✓ create task\n  ✓ list tasks\n  ✓ update task status\n  ✓ delete task\n\nRun:  venv\\Scripts\\pytest tests -v\nDB:   SQLite :memory: (isolated per test)","lineHeight":1.25},{"id":"e2e-test-box","type":"rectangle","x":1270,"y":540,"width":520,"height":550,"angle":0,"strokeColor":"#1971c2","backgroundColor":"#e7f5ff","fillStyle":"solid","strokeWidth":1,"strokeStyle":"dashed","roughness":0,"opacity":100,"groupIds":[],"roundness":{"type":3},"seed":22,"version":1,"versionNonce":22,"isDeleted":false},{"id":"e2e-test-label","type":"text","x":1360,"y":550,"width":340,"height":20,"angle":0,"strokeColor":"#1971c2","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":23,"version":1,"versionNonce":23,"isDeleted":false,"hasFixedBounds":false,"text":"E2E Browser Tests  (frontend/e2e/)","fontSize":13,"fontFamily":1,"textAlign":"center","verticalAlign":"top","baseline":11,"containerId":null,"originalText":"E2E Browser Tests  (frontend/e2e/)","lineHeight":1.25},{"id":"e2e-test-text","type":"text","x":1285,"y":578,"width":490,"height":500,"angle":0,"strokeColor":"#1971c2","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":24,"version":1,"versionNonce":24,"isDeleted":false,"hasFixedBounds":false,"text":"Setup (conftest.py):\n  • session-scoped admin_auth_state\n    → register once + OTP login → saves admin.json\n  • session-scoped employee_auth_state\n    → uses admin to create employee → saves employee.json\n  • All tests reuse saved auth state (no re-login)\n  • E2E_HEADLESS env var controls browser visibility\n\ntest_register.py      (unauthenticated fresh page)\n  ✓ register new company → redirect to /login\n  ✓ invalid phone shows error\n\ntest_dashboard.py     (admin session)\n  ✓ admin dashboard content visible\n  ✓ navigate to employees\n  ✓ navigate to tasks\n\ntest_employees.py     (admin session)\n  ✓ add new employee\n  ✓ view employee profile + login code\n\ntest_tasks.py         (admin session)\n  ✓ create new task\n  ✓ view reports history modal\n  ✓ edit task\n\ntest_employee_login.py  (employee session)\n  ✓ employee dashboard visible\n  ✓ employee sees own name\n  ✓ employee can view tasks\n  ✓ employee can navigate to employees page\n  ✓ employee task status update\n\nRun: pytest e2e -v  (from frontend/)\nPages: Playwright Chromium, localhost:3000","fontSize":13,"fontFamily":1,"textAlign":"left","verticalAlign":"top","baseline":12,"containerId":null,"originalText":"Setup (conftest.py):\n  • session-scoped admin_auth_state\n    → register once + OTP login → saves admin.json\n  • session-scoped employee_auth_state\n    → uses admin to create employee → saves employee.json\n  • All tests reuse saved auth state (no re-login)\n  • E2E_HEADLESS env var controls browser visibility\n\ntest_register.py      (unauthenticated fresh page)\n  ✓ register new company → redirect to /login\n  ✓ invalid phone shows error\n\ntest_dashboard.py     (admin session)\n  ✓ admin dashboard content visible\n  ✓ navigate to employees\n  ✓ navigate to tasks\n\ntest_employees.py     (admin session)\n  ✓ add new employee\n  ✓ view employee profile + login code\n\ntest_tasks.py         (admin session)\n  ✓ create new task\n  ✓ view reports history modal\n  ✓ edit task\n\ntest_employee_login.py  (employee session)\n  ✓ employee dashboard visible\n  ✓ employee sees own name\n  ✓ employee can view tasks\n  ✓ employee can navigate to employees page\n  ✓ employee task status update\n\nRun: pytest e2e -v  (from frontend/)\nPages: Playwright Chromium, localhost:3000","lineHeight":1.25},{"id":"runner-box","type":"rectangle","x":200,"y":240,"width":300,"height":200,"angle":0,"strokeColor":"#2f9e44","backgroundColor":"#d3f9d8","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":{"type":3},"seed":25,"version":1,"versionNonce":25,"isDeleted":false},{"id":"runner-label","type":"text","x":240,"y":250,"width":220,"height":20,"angle":0,"strokeColor":"#2f9e44","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":26,"version":1,"versionNonce":26,"isDeleted":false,"hasFixedBounds":false,"text":"🚀  run_all_tests.ps1","fontSize":15,"fontFamily":1,"textAlign":"center","verticalAlign":"top","baseline":13,"containerId":null,"originalText":"🚀  run_all_tests.ps1","lineHeight":1.25},{"id":"runner-text","type":"text","x":215,"y":280,"width":270,"height":150,"angle":0,"strokeColor":"#2f9e44","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":27,"version":1,"versionNonce":27,"isDeleted":false,"hasFixedBounds":false,"text":"Flags:\n  (default)     → backend + E2E\n  -BackendOnly  → API tests only\n  -FrontendOnly → E2E tests only\n  -Headless     → no browser window\n\n1. Run backend tests\n2. Run E2E tests\n3. Print summary table\n   (pass/fail counts + duration)","fontSize":13,"fontFamily":1,"textAlign":"left","verticalAlign":"top","baseline":12,"containerId":null,"originalText":"Flags:\n  (default)     → backend + E2E\n  -BackendOnly  → API tests only\n  -FrontendOnly → E2E tests only\n  -Headless     → no browser window\n\n1. Run backend tests\n2. Run E2E tests\n3. Print summary table\n   (pass/fail counts + duration)","lineHeight":1.25},{"id":"arrow-runner-be","type":"arrow","x":500,"y":300,"width":50,"height":0,"angle":0,"strokeColor":"#2f9e44","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":2,"strokeStyle":"dashed","roughness":0,"opacity":100,"groupIds":[],"roundness":{"type":2},"seed":28,"version":1,"versionNonce":28,"isDeleted":false,"startBinding":{"elementId":"runner-box","focus":0,"gap":1},"endBinding":{"elementId":"backend-test-box","focus":0,"gap":1},"lastCommittedPoint":null,"startArrowhead":null,"endArrowhead":"arrow","points":[[0,0],[750,0]]},{"id":"arrow-runner-e2e","type":"arrow","x":500,"y":380,"width":0,"height":0,"angle":0,"strokeColor":"#2f9e44","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":2,"strokeStyle":"dashed","roughness":0,"opacity":100,"groupIds":[],"roundness":{"type":2},"seed":29,"version":1,"versionNonce":29,"isDeleted":false,"startBinding":{"elementId":"runner-box","focus":0,"gap":1},"endBinding":{"elementId":"e2e-test-box","focus":0,"gap":1},"lastCommittedPoint":null,"startArrowhead":null,"endArrowhead":"arrow","points":[[0,0],[770,260]]},{"id":"login-flow-box","type":"rectangle","x":20,"y":590,"width":380,"height":420,"angle":0,"strokeColor":"#862e9c","backgroundColor":"#f3d9fa","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":{"type":3},"seed":30,"version":1,"versionNonce":30,"isDeleted":false},{"id":"login-flow-label","type":"text","x":100,"y":600,"width":220,"height":20,"angle":0,"strokeColor":"#862e9c","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":31,"version":1,"versionNonce":31,"isDeleted":false,"hasFixedBounds":false,"text":"🔐  Auth Flow","fontSize":15,"fontFamily":1,"textAlign":"center","verticalAlign":"top","baseline":13,"containerId":null,"originalText":"🔐  Auth Flow","lineHeight":1.25},{"id":"login-flow-text","type":"text","x":35,"y":630,"width":355,"height":370,"angle":0,"strokeColor":"#862e9c","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":32,"version":1,"versionNonce":32,"isDeleted":false,"hasFixedBounds":false,"text":"ADMIN LOGIN (OTP)\n  1. Enter phone number\n  2. POST /send-otp → OTP generated\n       (returned in dev mode)\n  3. Enter 6-digit OTP\n  4. POST /verify-otp → JWT token\n  5. JWT stored in localStorage\n  6. Redirect → /dashboard (admin)\n\nEMPLOYEE LOGIN (Login Code)\n  1. Enter phone number\n  2. #loginCode input appears\n  3. Enter 'Emp...' code from profile\n  4. POST /verify-otp (with code)\n  5. JWT stored in localStorage\n  6. Redirect → /dashboard (employee)\n\nTOKEN USAGE\n  • Every API call sends:\n    Authorization: Bearer <JWT>\n  • Backend decodes → role + phone\n  • Admin: full CRUD access\n  • Employee: own tasks only","fontSize":13,"fontFamily":1,"textAlign":"left","verticalAlign":"top","baseline":12,"containerId":null,"originalText":"ADMIN LOGIN (OTP)\n  1. Enter phone number\n  2. POST /send-otp → OTP generated\n       (returned in dev mode)\n  3. Enter 6-digit OTP\n  4. POST /verify-otp → JWT token\n  5. JWT stored in localStorage\n  6. Redirect → /dashboard (admin)\n\nEMPLOYEE LOGIN (Login Code)\n  1. Enter phone number\n  2. #loginCode input appears\n  3. Enter 'Emp...' code from profile\n  4. POST /verify-otp (with code)\n  5. JWT stored in localStorage\n  6. Redirect → /dashboard (employee)\n\nTOKEN USAGE\n  • Every API call sends:\n    Authorization: Bearer <JWT>\n  • Backend decodes → role + phone\n  • Admin: full CRUD access\n  • Employee: own tasks only","lineHeight":1.25}],"appState":{"viewBackgroundColor":"#ffffff","gridSize":null},"files":{}}
